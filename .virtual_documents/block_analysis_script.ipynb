if not avg_crossovers_per_gen.empty and not avg_crossovers_per_diploid_chrom.empty:

    # --- Dynamic and Robust Generation Ordering Function ---
    def get_generation_sort_key(gen_name):
        if gen_name == 'P_A': return (0, 0, '')
        if gen_name == 'P_B': return (1, 0, '')
        if gen_name.startswith('F'):
            try:
                num = int(gen_name[1:])
                return (2, num, '')
            except ValueError:
                return (2, 99999, gen_name)
        if gen_name.startswith('BC'):
            try:
                num_part = gen_name[2:-1] # e.g., '1' from 'BC1A'
                letter_part = gen_name[-1] # e.g., 'A' from 'BC1A'
                num = int(num_part)
                letter_val = 0 if letter_part == 'A' else (1 if letter_part == 'B' else 999)
                return (3, num, letter_val)
            except ValueError:
                return (3, 99999, gen_name)
        return (4, gen_name) # Any other unexpected generations come last


    # --- Filter Data for F-Generations and BC-Generations ---

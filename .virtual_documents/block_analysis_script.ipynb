    # Helper function to plot average block trends (line and scatter)
    def _plot_average_trend(data_df, title_prefix, y_column, sorted_order):
        """
        Generates a line plot with scatter points for average block trends.

        Args:
            data_df (pd.DataFrame): DataFrame containing average block data per generation.
            title_prefix (str): Prefix for the plot title (e.g., 'F-Generations').
            y_column (str): Name of the column to plot on the Y-axis (e.g., 'Average_Num_Blocks_Across_Individuals_Per_Chromosome').
            sorted_order (list): List of generation labels in the desired plotting order.
        """
        if data_df.empty:
            print(f"No data available for {title_prefix} average trend plot.")
            return

        # Ensure correct categorical ordering for plotting
        data_df['Generation_Order_Cat'] = pd.Categorical(
            data_df['Generation'],
            categories=sorted_order,
            ordered=True
        )
        data_df_sorted = data_df.sort_values('Generation_Order_Cat').dropna(subset=['Generation_Order_Cat'])

        if data_df_sorted.empty:
            print(f"No valid sorted data after categorical conversion for {title_prefix} average trend plot.")
            return

        plt.figure(figsize=(12, 6))
        sns.lineplot(data=data_df_sorted, x='Generation', y=y_column, marker='o',
                     hue='Generation_Order_Cat', palette='viridis', legend=False)
        sns.scatterplot(data=data_df_sorted, x='Generation', y=y_column, s=100,
                        hue='Generation_Order_Cat', palette='viridis', legend=False)
        plt.title(f'{title_prefix}: Average Number of Blocks per Diploid Chromosome per Individual')
        plt.xlabel('Generation')
        plt.ylabel('Average Number of Blocks')
        plt.xticks(rotation=45, ha='right')
        plt.tight_layout()
        ax = plt.gca()
        ax.yaxis.set_major_locator(ticker.MultipleLocator(base=1)) # Y-axis ticks in 1s
        plt.show()

    # Helper function to plot block distributions (violin/box plots)
    def _plot_distribution(data_df, title_prefix, y_column, sorted_order, plot_type='violin'):
        """
        Generates a violin or box plot for block distributions.

        Args:
            data_df (pd.DataFrame): DataFrame containing individual block data.
            title_prefix (str): Prefix for the plot title (e.g., 'F-Generations').
            y_column (str): Name of the column to plot on the Y-axis (e.g., 'Avg_Blocks_Per_Diploid_Chromosome_Per_Individual').
            sorted_order (list): List of generation labels in the desired plotting order.
            plot_type (str): 'violin' or 'box' to choose the plot type.
        """
        if data_df.empty:
            print(f"No data available for {title_prefix} {plot_type} plot.")
            return

        plt.figure(figsize=(14, 8))
        if plot_type == 'violin':
            sns.violinplot(data=data_df, x='Generation', y=y_column,
                           order=sorted_order, palette='viridis', inner='quartile',
                           hue='Generation', legend=False)
        elif plot_type == 'box':
            sns.boxplot(data=data_df, x='Generation', y=y_column,
                        order=sorted_order, palette='viridis',
                        hue='Generation', legend=False)
        else:
            print(f"Invalid plot_type: {plot_type}. Must be 'violin' or 'box'.")
            return

        plt.title(f'{title_prefix}: Distribution of Number of Blocks per Diploid Chromosome per Individual ({plot_type.capitalize()} Plot)')
        plt.xlabel('Generation')
        plt.ylabel('Number of Blocks per Diploid Chromosome')
        plt.xticks(rotation=45, ha='right')
        plt.tight_layout()
        ax = plt.gca()
        ax.yaxis.set_major_locator(ticker.MultipleLocator(base=1)) # Y-axis ticks in 1s
        plt.show()



def sort_generations(generation_label):
    if generation_label.startswith('F'):
        try:
            return (0, int(re.search(r'F(\d+)', generation_label).group(1)), '')
        except (ValueError, AttributeError):
            return (0, 9999, generation_label)
    elif generation_label.startswith('BC'):
        match = re.match(r'BC(\d+)([AB]?)', generation_label)
        if match:
            return (1, int(match.group(1)), match.group(2))
        else:
            return (1, 9999, generation_label)
    else: # For P_A, P_B
        if generation_label == 'P_A':
            return (-1, 0, '')
        elif generation_label == 'P_B':
            return (-1, 1, '')
        return (2, 0, generation_label)

plot_data_melted_prop['Generation_Sort_Key'] = plot_data_melted_prop['Generation'].apply(sort_generations)
plot_data_melted_prop.sort_values(by='Generation_Sort_Key', inplace=True)


# --- Helper Functions ---

def map_genotype_to_numeric(genotype_str):
    """
    Converts a genotype string (e.g., '0|0', '0|2') to a numeric genotype (0, 1, 2).
    - 0: Homozygous for allele 0 (P_A/P_A)
    - 1: Heterozygous (P_A/P_B)
    - 2: Homozygous for allele 2 (P_B/P_B)
    Returns None for unexpected formats.
    """
    if not isinstance(genotype_str, str):
        print(f"Warning: Encountered a non-string genotype '{genotype_str}'. Returning None.")
        return None

    # Split and sort alleles to handle '0|2' and '2|0' identically
    alleles = tuple(sorted(genotype_str.split('|')))

    if alleles == ('0', '0'):
        return 0
    elif alleles == ('0', '2'):
        return 1
    elif alleles == ('2', '2'):
        return 2
    else:
        print(f"Warning: Found an unexpected genotype string '{genotype_str}'. Returning None.")
        return None


def sort_generations(generation_label):
    """
    Provides a sort key for generation labels (F1, F2, BC1A, P_A, etc.)
    to ensure logical ordering in plots and dataframes.
    """
    if generation_label.startswith('F'):
        try:
            # F-generations come after P and before BC, sorted numerically
            return (0, int(re.search(r'F(\d+)', generation_label).group(1)), '')
        except (ValueError, AttributeError):
            return (0, 9999, generation_label) # Fallback for malformed F-labels
    elif generation_label.startswith('BC'):
        match = re.match(r'BC(\d+)([AB]?)', generation_label)
        if match:
            # BC-generations come after F, sorted numerically then alphabetically by suffix
            return (1, int(match.group(1)), match.group(2))
        else:
            return (1, 9999, generation_label) # Fallback for malformed BC-labels
    else: # For P_A, P_B, etc.
        # Pure populations (P_A, P_B) appear at the very beginning
        if generation_label == 'P_A':
            return (-1, 0, '') # P_A first
        elif generation_label == 'P_B':
            return (-1, 1, '') # P_B second
        return (2, 0, generation_label) # Fallback for any other labels, put at the end


